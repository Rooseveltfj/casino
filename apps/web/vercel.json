{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm build --filter=web",
  "installCommand": "corepack enable pnpm && cd ../.. && pnpm install --frozen-lockfile",
  "outputDirectory": ".next",
  "env": {
    "DATABASE_URL":           "@database-url",
    "BETTER_AUTH_SECRET":     "@better-auth-secret",
    "NEXT_PUBLIC_APP_URL":    "@next-public-app-url",
    "NEXT_PUBLIC_APP_NAME":   "@next-public-app-name",
    "NEXT_PUBLIC_API_URL":    "@next-public-api-url",
    "SENTRY_DSN":             "@sentry-dsn",
    "NEXT_PUBLIC_SENTRY_DSN": "@next-public-sentry-dsn",
    "SENTRY_AUTH_TOKEN":      "@sentry-auth-token",
    "SENTRY_ORG":             "@sentry-org",
    "SENTRY_PROJECT":         "@sentry-project"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://api.example.com/api/v1/:path*"
    }
  ]
}
