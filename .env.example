# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Supabase, Neon, local Docker, etc.)
DATABASE_URL="postgresql://postgres:password@localhost:5432/casino_dev"

# Set to "true" to log every SQL query to stdout
DB_DEBUG="false"

# ─── Auth (Better-Auth) ────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="change-me-to-a-random-32-char-string"
BETTER_AUTH_URL="http://localhost:3000"

# ─── Redis (Upstash or local) ─────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# Upstash REST (optional, for edge-compatible client)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Casino Platform"

# ─── Game providers (real values needed only in production) ────────────────────
PRAGMATIC_API_KEY=""
PRAGMATIC_API_SECRET=""
EVOLUTION_API_KEY=""
EVOLUTION_API_SECRET=""

# ─── PSP (Pix — stub in demo mode) ────────────────────────────────────────────
# In demo: deposits are confirmed manually by admin in the backoffice
PIX_ENCRYPTION_KEY="change-me-to-a-32-byte-aes-key!!"
WOOVI_API_KEY=""
WOOVI_WEBHOOK_SECRET=""
