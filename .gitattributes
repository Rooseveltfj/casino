# Normalize line endings to LF in the repository
* text=auto eol=lf

# Force binary treatment for specific file types
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.eot  binary

# Ensure shell scripts always use LF
*.sh   eol=lf
